{% extends 'auth.base' %}

{% block title %}{{ trans('Blessing\\OAuth\\OIDC::general.link_title') }}{% endblock %}

{% block content %}
{% if emailExists %}
  {# ── Case A：邮箱在系统中有对应账户 ── #}
  <p class="mb-4">
      {{ trans('Blessing\\OAuth\\OIDC::general.account_found_desc', {'email': email, 'provider': oidc_name}) }}
  </p>

  {% if nickname is not empty %}
  <p class="text-muted mb-4">
      <small>{{ trans('Blessing\\OAuth\\OIDC::general.nickname_from_provider', {'provider': oidc_name}) }}: {{ nickname }}</small>
  </p>
  {% endif %}

  <div class="row">
    <div class="col-12 mb-3">
      <div class="card">
        <div class="card-body text-center">
          <h5 class="card-title">
            <i class="fa fa-link mr-2"></i>
            {{ trans('Blessing\\OAuth\\OIDC::general.account_found_title') }}
          </h5>
          <p class="card-text text-muted">
            {{ trans('Blessing\\OAuth\\OIDC::general.link_info') }}
          </p>
          <form action="{{ route('oidc.link.auto-link') }}" method="POST">
            {{ csrf_field()|raw }}
            <button type="submit" class="btn btn-primary">
              {{ trans('Blessing\\OAuth\\OIDC::general.auto_link_button') }}
            </button>
          </form>
        </div>
      </div>
    </div>
    <div class="col-12 mb-3">
      <div class="card">
        <div class="card-body text-center">
          <h5 class="card-title">
            <i class="fa fa-user-circle mr-2"></i>
            {{ trans('Blessing\\OAuth\\OIDC::general.use_other_account') }}
          </h5>
          <p class="card-text text-muted">
            {{ trans('Blessing\\OAuth\\OIDC::general.use_other_account_desc') }}
          </p>
          <a href="{{ login_url }}" class="btn btn-secondary">
            {{ trans('Blessing\\OAuth\\OIDC::general.login_to_link') }}
          </a>
        </div>
      </div>
    </div>
  </div>
{% else %}
  {# ── Case B：邮箱未在系统中注册 ── #}
  <p class="mb-4">
      {{ trans('Blessing\\OAuth\\OIDC::general.link_description', {'email': email, 'provider': oidc_name}) }}
  </p>

  {% if nickname is not empty %}
  <p class="text-muted mb-4">
      <small>{{ trans('Blessing\\OAuth\\OIDC::general.nickname_from_provider', {'provider': oidc_name}) }}: {{ nickname }}</small>
  </p>
  {% endif %}

  <div class="row">
    <div class="col-12 mb-3">
      <div class="card">
        <div class="card-body text-center">
          <h5 class="card-title">
            <i class="fa fa-user-plus mr-2"></i>
            {{ trans('Blessing\\OAuth\\OIDC::general.create_new') }}
          </h5>
          <p class="card-text text-muted">
            {{ trans('Blessing\\OAuth\\OIDC::general.create_new_desc') }}
          </p>
          <form action="{{ route('oidc.link.create') }}" method="POST">
            {{ csrf_field()|raw }}
            <button type="submit" class="btn btn-success">
              {{ trans('Blessing\\OAuth\\OIDC::general.create_account') }}
            </button>
          </form>
        </div>
      </div>
    </div>
    <div class="col-12 mb-3">
      <div class="card">
        <div class="card-body text-center">
          <h5 class="card-title">
            <i class="fa fa-link mr-2"></i>
            {{ trans('Blessing\\OAuth\\OIDC::general.link_existing') }}
          </h5>
          <p class="card-text text-muted">
            {{ trans('Blessing\\OAuth\\OIDC::general.link_existing_desc') }}
          </p>
          <a href="{{ login_url }}" class="btn btn-primary">
            {{ trans('Blessing\\OAuth\\OIDC::general.login_to_link') }}
          </a>
        </div>
      </div>
    </div>
  </div>
{% endif %}

<div class="alert alert-info mt-4">
    <i class="fa fa-info-circle mr-2"></i>
    {{ trans('Blessing\\OAuth\\OIDC::general.link_info') }}
</div>
{% endblock %}
